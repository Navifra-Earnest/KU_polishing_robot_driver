<launch>
  <!-- 파라미터 파일 (기본: 패키지 config) -->
  <arg name="params_file" default="$(find motor_driver)/config/motor_driver.yaml"/>

  <node pkg="motor_driver" type="motor_driver_node" name="motor_driver_node" output="screen">
    <rosparam command="load" file="$(arg params_file)"/>
  </node>

</launch>
