<launch>
  <!-- 리프트 드라이버 (MDROBOT MD DC 모터, RS485 / COM1)
       입력: /lift/command(String up/down/stop), /lift/velocity_cmd(Int16), /estop(Bool)
       출력: /lift/position(Int32), /lift/status(String) -->
  <arg name="lift_params" default="$(find lift_driver)/config/lift_driver.yaml"/>

  <node pkg="lift_driver" type="lift_driver_node" name="lift_driver" output="screen">
    <rosparam command="load" file="$(arg lift_params)"/>
  </node>
</launch>
